# Primjer: kopiraj u .env.local (ne commitaj) i popuni value.
# Na Vercel/Netlify: environment variables (ne u repozitorij).
# Vercel: nakon "Storage → Create Blob" za site, BLOB_READ_WRITE_TOKEN se doda automatski.
# Ako je Google API ključ bio u slici, commitu ili javnom fajlu — rotiraj ga u Google Cloud Console.

# --- Public site URL (metadata, sitemap, robots, OG) ---
# Kanonski origin (www). NIKAD *.vercel.app.
# Sitemap: https://www.mpark-sarajevo.com/sitemap.xml
# Apex u adresi: vercel.json šalje apex → www (bez suprotnog www→apex u projektu).
NEXT_PUBLIC_SITE_URL=https://www.mpark-sarajevo.com

# Google Analytics 4 — opcionalno; ako je prazno, koristi se G-TSDCML52W1 u kodu (components/GoogleAnalytics.jsx).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Email obavijesti (nova rezervacija; Gmail App Password, NE obična lozinka) ---
# Na Vercelu označiti GMAIL_PASS kao Sensitive. Koristi App Password (ne prijavnu lozinku).
GMAIL_USER=
GMAIL_PASS=
ADMIN_EMAIL=

# --- Admin (samo server; obavezno u produkciji) ---
# Lokalni dev: ako ovo ostane prazno, koriste se ugrađeni dev defaulti (pogledaj lib/auth.js).
# Produkcija: MORA biti postavljeno.
ADMIN_PASSWORD=
# Min. 32 znaka. Primjer: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_SESSION_SECRET=

# --- Skladište ---
# Lokalno: JSON. Na Vercelu: obavezno Vercel Blob (token se injecta), ne ručno unositi.
RESERVATIONS_FILE=./data/reservations.json

# --- Google recenzije (samo server; ISR cache ~6h) ---
# https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Javni link ka kartici biznisa na Google Maps (preporuka: /maps/place/... ili URL sa cid=).
# Generička maps pretraga (?query=) se NE koristi u schema.org sameAs — ostaje prazno dok ne postavite konkretan listings URL.
NEXT_PUBLIC_GOOGLE_PROFILE_URL=

# Direktan link za ostavljanje Google recenzije (Google Business Profile → "Get more reviews").
# Koristi se u potvrdi rezervacije e-poštom i WhatsApp CTA nakon rezervacije na sajtu.
NEXT_PUBLIC_GOOGLE_REVIEW_URL=
# Opcija samo za server (ako želite držati URL izvan NEXT_PUBLIC); inače ostavite prazno.
GOOGLE_BUSINESS_REVIEW_URL=
