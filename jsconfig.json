{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "checkJs": false
  },
  "include": [
    "app/**/*",
    "components/**/*",
    "lib/**/*",
    "data/**/*",
    "i18n/**/*",
    "messages/**/*",
    "middleware.js"
  ],
  "exclude": ["node_modules", ".next"]
}
