{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "mpark-sarajevo.vercel.app"
        }
      ],
      "destination": "https://www.mpark-sarajevo.com/:path*",
      "permanent": true
    },
